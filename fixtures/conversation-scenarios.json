[
  {
    "name": "order lookup after customer sends phone",
    "steps": [
      {
        "message": "где мой заказ",
        "expect": {
          "intent": "order_status",
          "action": "ask_clarifying_question",
          "contextRequestType": "order"
        }
      },
      {
        "message": "+7 999 123 45 67",
        "orderContext": {
          "orderNumber": "6_L",
          "status": "PROCESSING",
          "deliveryMethod": "CDEK_PVZ",
          "cdekTrackingNumber": "1234567890"
        },
        "expect": {
          "intent": "order_status",
          "action": "answer",
          "answerIncludes": ["Нашел заказ #6_L", "в обработке", "Трек CDEK"],
          "answerExcludes": ["Пришлите номер заказа"]
        }
      }
    ]
  },
  {
    "name": "product availability with model in first message",
    "steps": [
      {
        "message": "wlmouse beast max есть?",
        "expect": {
          "intent": "availability",
          "action": "ask_clarifying_question",
          "contextRequestType": "product",
          "contextRequestStrategy": "by_hint",
          "answerIncludes": ["по этому товару"],
          "answerExcludes": ["Пришлите ссылку"]
        }
      },
      {
        "message": "wlmouse beast max есть?",
        "productContext": {
          "name": "WLmouse Beast Max",
          "quantity": 3,
          "price": 15990,
          "sklad": "Москва"
        },
        "expect": {
          "intent": "availability",
          "action": "answer",
          "answerIncludes": ["WLmouse Beast Max", "В наличии 3 шт.", "Цена"]
        }
      }
    ]
  },
  {
    "name": "site checkout problem goes to operator",
    "steps": [
      {
        "message": "не могу оформить заказ, сайт выдает ошибку в корзине",
        "expect": {
          "intent": "site_issue",
          "action": "handoff_to_operator",
          "handoffReason": "site_issue",
          "answerIncludes": ["помогли оформить"]
        }
      }
    ]
  },
  {
    "name": "ambiguous order lookup asks for exact id",
    "steps": [
      {
        "message": "Иванов",
        "session": {
          "pendingRequest": {
            "type": "order",
            "intent": "order_status"
          }
        },
        "orderContext": {
          "lookupStatus": "multiple"
        },
        "expect": {
          "intent": "order_status",
          "action": "ask_clarifying_question",
          "contextRequestStrategy": "ask_for_exact_hint",
          "answerIncludes": ["несколько похожих заказов", "номер заказа", "трек CDEK", "последний"]
        }
      }
    ]
  },
  {
    "name": "external link request goes to manual calculation",
    "steps": [
      {
        "message": "можно заказать по ссылке https://example.com/item/123 размер m черный",
        "expect": {
          "intent": "custom_order_request",
          "action": "handoff_to_operator",
          "handoffReason": "custom_order_request",
          "answerIncludes": ["ручной расчет"]
        }
      }
    ]
  },
  {
    "name": "site search problem asks for product hint",
    "steps": [
      {
        "message": "я не могу найти wlmouse beast на сайте",
        "expect": {
          "intent": "product_search",
          "action": "ask_clarifying_question",
          "contextRequestType": "product",
          "contextRequestStrategy": "by_hint",
          "answerIncludes": ["Проверю этот товар", "не отображается на сайте"],
          "answerExcludes": ["Что именно нужно?"]
        }
      }
    ]
  },
  {
    "name": "refund money wait goes to payment review",
    "steps": [
      {
        "message": "прошло больше 10 дней, деньги не вернулись",
        "expect": {
          "intent": "payment",
          "action": "handoff_to_operator",
          "handoffReason": "billing_issue",
          "answerIncludes": ["проверили платеж"]
        }
      }
    ]
  },
  {
    "name": "review question gets a direct answer",
    "steps": [
      {
        "message": "где отзывы оставлять можно?",
        "expect": {
          "intent": "review",
          "action": "answer",
          "answerIncludes": ["карточке товара"]
        }
      }
    ]
  },
  {
    "name": "international delivery goes to operator",
    "steps": [
      {
        "message": "доставляете в Беларусь?",
        "expect": {
          "intent": "international_delivery",
          "action": "handoff_to_operator",
          "handoffReason": "international_delivery",
          "answerIncludes": ["Международную доставку", "передаю оператору"]
        }
      }
    ]
  },
  {
    "name": "general help topic reply routes to product availability",
    "steps": [
      {
        "message": "можете подсказать?",
        "expect": {
          "intent": "general_help",
          "action": "ask_clarifying_question",
          "contextRequestType": "general"
        }
      },
      {
        "message": "наличие",
        "expect": {
          "intent": "availability",
          "action": "ask_clarifying_question",
          "contextRequestType": "product",
          "contextRequestStrategy": "ask_for_hint",
          "answerIncludes": ["Проверю наличие"],
          "answerExcludes": ["Что именно нужно?"]
        }
      }
    ]
  },
  {
    "name": "general help topic reply routes to delivery terms",
    "steps": [
      {
        "message": "можете подсказать?",
        "expect": {
          "intent": "general_help",
          "action": "ask_clarifying_question",
          "contextRequestType": "general"
        }
      },
      {
        "message": "доставка",
        "expect": {
          "intent": "delivery_terms",
          "action": "answer",
          "answerIncludes": ["Срок зависит от города"],
          "answerExcludes": ["Пришлите номер заказа"]
        }
      }
    ]
  },
  {
    "name": "details after human handoff are appended to same request",
    "steps": [
      {
        "message": "позови оператора",
        "expect": {
          "intent": "human_requested",
          "action": "handoff_to_operator",
          "handoffReason": "requested_human"
        }
      },
      {
        "message": "номер заказа 12345",
        "expect": {
          "intent": "human_requested",
          "action": "handoff_to_operator",
          "handoffReason": "requested_human",
          "appendToExistingHandoff": true,
          "answerIncludes": ["Добавил это к обращению", "повторять заново не нужно"],
          "answerExcludes": ["Пришлите номер заказа"]
        }
      }
    ]
  },
  {
    "name": "custom order details after handoff are appended",
    "steps": [
      {
        "message": "можно заказать по ссылке https://example.com/item/123",
        "expect": {
          "intent": "custom_order_request",
          "action": "handoff_to_operator",
          "handoffReason": "custom_order_request"
        }
      },
      {
        "message": "размер m, цвет черный, 1 штука",
        "expect": {
          "intent": "custom_order_request",
          "action": "handoff_to_operator",
          "handoffReason": "custom_order_request",
          "appendToExistingHandoff": true,
          "answerIncludes": ["Добавил это к обращению"]
        }
      }
    ]
  },
  {
    "name": "acknowledgement closes human handoff context",
    "steps": [
      {
        "message": "позови оператора",
        "expect": {
          "intent": "human_requested",
          "action": "handoff_to_operator",
          "handoffReason": "requested_human"
        }
      },
      {
        "message": "спасибо",
        "expect": {
          "intent": "acknowledgement",
          "action": "answer"
        }
      },
      {
        "message": "где мой заказ",
        "expect": {
          "intent": "order_status",
          "action": "ask_clarifying_question",
          "contextRequestType": "order",
          "answerExcludes": ["Добавил это к обращению"]
        }
      }
    ]
  },
  {
    "name": "acknowledgement closes custom order handoff context",
    "steps": [
      {
        "message": "можно заказать по ссылке https://example.com/item/123",
        "expect": {
          "intent": "custom_order_request",
          "action": "handoff_to_operator",
          "handoffReason": "custom_order_request"
        }
      },
      {
        "message": "размер m, цвет черный",
        "expect": {
          "intent": "custom_order_request",
          "action": "handoff_to_operator",
          "handoffReason": "custom_order_request",
          "appendToExistingHandoff": true
        }
      },
      {
        "message": "спасибо",
        "expect": {
          "intent": "acknowledgement",
          "action": "answer"
        }
      },
      {
        "message": "где мой заказ",
        "expect": {
          "intent": "order_status",
          "action": "ask_clarifying_question",
          "contextRequestType": "order",
          "answerExcludes": ["Добавил это к обращению"]
        }
      }
    ]
  }
]
