TELEGRAM_BOT_TOKEN=

# Optional: send handoff notifications to a manager/group chat.
OPERATOR_CHAT_ID=

# Optional JSON arrays. Leave empty for safe FAQ-only mode without fake orders/products.
RESHIP_ORDERS_JSON=
RESHIP_PRODUCTS_JSON=

# Live ReShip data sources.
RESHIP_PRODUCTS_LIVE_ENABLED=true
RESHIP_PRODUCTS_API_URL=https://reship.pro/api/products/search
RESHIP_PRODUCTS_SEARCH_LIMIT=20

# For live order lookup, either set a protected lookup API:
RESHIP_ORDERS_LIVE_ENABLED=true
RESHIP_ORDERS_LOOKUP_URL=
RESHIP_ORDERS_API_SECRET=

# Or set Supabase service credentials directly on the server.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESHIP_ORDERS_LOOKUP_LIMIT=20

# LLM fallback. Default is safe mock/shadow.
LLM_ENABLED=true
LLM_SHADOW=true
LLM_PROVIDER=mock

# Set LLM_PROVIDER=openai to call the real OpenAI Responses API.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_MS=12000
OPENAI_MAX_OUTPUT_TOKENS=700
OPENAI_TEMPERATURE=0.2
OPENAI_REASONING_EFFORT=minimal

# Learning/analytics logs are redacted JSONL files ignored by git.
ANALYTICS_ENABLED=true
ANALYTICS_DIR=learning/events
LEARNING_ENABLED=true
LEARNING_DIR=learning/inbox
